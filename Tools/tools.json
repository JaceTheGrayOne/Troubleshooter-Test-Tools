{
  "tools": [
    {
      "id": "remote-access",
      "name": "Remote Access",
      "script": "Scripts/RemoteAccess.ps1",
      "interactiveInput": true,
      "presetsPath": "Tools/remote-access.presets.json",
      "fields": [
        {
          "name": "PresetId",
          "type": "hidden",
          "default": ""
        },
        {
          "name": "Action",
          "type": "hidden",
          "default": ""
        },
        {
          "name": "Protocol",
          "label": "Protocol",
          "type": "choice",
          "default": "Telnet",
          "options": [
            "Telnet",
            "Serial"
          ]
        },
        {
          "name": "PollMilliseconds",
          "label": "Poll Interval (ms)",
          "type": "number",
          "default": 75,
          "minimum": 10,
          "maximum": 5000
        },
        {
          "name": "ReceiveBufferBytes",
          "label": "Receive Buffer (bytes)",
          "type": "number",
          "default": 4096,
          "minimum": 128,
          "maximum": 65536
        },
        {
          "name": "TargetHost",
          "label": "Target Host / IP",
          "default": "",
          "visibleWhen": {
            "Protocol": "Telnet"
          }
        },
        {
          "name": "TcpPort",
          "label": "TCP Port",
          "type": "number",
          "default": 23,
          "minimum": 1,
          "maximum": 65535,
          "visibleWhen": {
            "Protocol": "Telnet"
          }
        },
        {
          "name": "ConnectTimeoutMilliseconds",
          "label": "Connect Timeout (ms)",
          "type": "number",
          "default": 10000,
          "minimum": 100,
          "maximum": 60000,
          "visibleWhen": {
            "Protocol": "Telnet"
          }
        },
        {
          "name": "ComPort",
          "label": "COM Port",
          "default": "",
          "visibleWhen": {
            "Protocol": "Serial"
          }
        },
        {
          "name": "BaudRate",
          "label": "Baud Rate",
          "type": "number",
          "default": 9600,
          "minimum": 300,
          "maximum": 921600,
          "visibleWhen": {
            "Protocol": "Serial"
          }
        },
        {
          "name": "Parity",
          "label": "Parity",
          "type": "choice",
          "default": "None",
          "options": [
            "None",
            "Odd",
            "Even",
            "Mark",
            "Space"
          ],
          "visibleWhen": {
            "Protocol": "Serial"
          }
        },
        {
          "name": "DataBits",
          "label": "Data Bits",
          "type": "number",
          "default": 8,
          "minimum": 5,
          "maximum": 8,
          "visibleWhen": {
            "Protocol": "Serial"
          }
        },
        {
          "name": "StopBits",
          "label": "Stop Bits",
          "type": "choice",
          "default": "One",
          "options": [
            "One",
            "Two",
            "OnePointFive"
          ],
          "visibleWhen": {
            "Protocol": "Serial"
          }
        },
        {
          "name": "Username",
          "label": "Username",
          "default": "",
          "visibleWhen": {
            "Protocol": "Serial",
            "Action": "SpectracomGpsAuth"
          }
        },
        {
          "name": "Password",
          "label": "Password",
          "type": "password",
          "default": "",
          "visibleWhen": {
            "Protocol": "Serial",
            "Action": "SpectracomGpsAuth"
          }
        },
        {
          "name": "WakePrompt",
          "label": "Wake Prompt",
          "type": "checkbox",
          "default": true,
          "visibleWhen": {
            "Protocol": "Serial",
            "Action": "SpectracomGpsAuth"
          }
        },
        {
          "name": "OpenDelayMilliseconds",
          "label": "Open Delay (ms)",
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 10000,
          "visibleWhen": {
            "Protocol": "Serial",
            "Action": "SpectracomGpsAuth"
          }
        },
        {
          "name": "PromptDelayMilliseconds",
          "label": "Prompt Delay (ms)",
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 10000,
          "visibleWhen": {
            "Protocol": "Serial",
            "Action": "SpectracomGpsAuth"
          }
        }
      ]
    },
    {
      "id": "network-monitor",
      "name": "Network Monitor",
      "launchPath": "ENTER_NETWORK_MONITOR_PATH_HERE",
      "launchButtonText": "Launch",
      "fields": []
    },
    {
      "id": "test-report-parser",
      "name": "Test Report Parser",
      "launchPath": "ENTER_PARSER_PATH_HERE",
      "launchButtonText": "Launch",
      "fields": []
    }
  ]
}
