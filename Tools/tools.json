{
  "tools": [
    {
      "id": "spectracom-gps-auth",
      "name": "Spectracom GPS Auth",
      "description": "Authenticates a Spectracom SecureSync over serial. It wakes the prompt, checks whether authentication is already valid, and sends credentials only when needed.",
      "script": "Scripts/SpectracomGpsAuth.ps1",
      "fields": [
        {
          "name": "Port",
          "label": "COM Port",
          "default": "COM1"
        },
        {
          "name": "BaudRate",
          "label": "Baud Rate",
          "type": "number",
          "default": 9600,
          "minimum": 300,
          "maximum": 921600
        },
        {
          "name": "Parity",
          "label": "Parity",
          "type": "choice",
          "default": "None",
          "options": [
            "None",
            "Odd",
            "Even",
            "Mark",
            "Space"
          ]
        },
        {
          "name": "DataBits",
          "label": "Data Bits",
          "type": "number",
          "default": 8,
          "minimum": 5,
          "maximum": 8
        },
        {
          "name": "StopBits",
          "label": "Stop Bits",
          "type": "choice",
          "default": "One",
          "options": [
            "One",
            "Two",
            "OnePointFive"
          ]
        },
        {
          "name": "Username",
          "label": "Username",
          "default": "spadmin"
        },
        {
          "name": "Password",
          "label": "Password",
          "type": "password",
          "default": "admin123"
        },
        {
          "name": "WakePrompt",
          "label": "Wake Prompt",
          "type": "checkbox",
          "default": true
        }
      ]
    },
    {
      "id": "rmup-console",
      "name": "RMUP Console",
      "description": "Native telnet console for the RMUP software-load log at 192.168.200.100:23 with prompted command input.",
      "script": "Scripts/RmupConsole.ps1",
      "interactiveInput": true,
      "fields": [
        {
          "name": "TargetHost",
          "label": "Target Host / IP",
          "default": "192.168.200.100"
        },
        {
          "name": "Port",
          "label": "Port",
          "type": "number",
          "default": 23,
          "minimum": 1,
          "maximum": 65535
        },
        {
          "name": "ConnectTimeoutMilliseconds",
          "label": "Connect Timeout (ms)",
          "type": "number",
          "default": 10000,
          "minimum": 100,
          "maximum": 60000
        }
      ]
    }
  ]
}
